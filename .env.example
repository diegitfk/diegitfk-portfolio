# 1. Conexión DIRECTA (Puerto 5432)
# Usada para Desarrollo local y Migraciones (soporta cambios de esquema)
DATABASE_URI_DIRECT="postgresql://postgres.user:pass@aws-1.pooler.supabase.com:5432/postgres"

# 2. Conexión POOL (Puerto 6543)
# Usada para Producción (soporta miles de usuarios, pero no cambios de esquema)
DATABASE_URI_POOL="postgresql://postgres.user:pass@aws-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

PAYLOAD_SECRET=YOUR_SECRET_HERE
PAYLOAD_MCP_TOKEN=YOUR_API_KEY_MCP


S3_BUCKET=YOUR_BUCKET_NAME
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY
S3_REGION=YOUR_S3_REGION
S3_ENDPOINT=YOUR_S3_ENDPOINT

OPENAI_API_KEY=your-api-key
NVIDIA_API_KEY=your-nvidia-api-key
