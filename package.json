{
  "name": "diegitfk-portfolio",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --turbopack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start --turbopack",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.22",
    "@ai-sdk/react": "^2.0.106",
    "@mastra/ai-sdk": "^0.3.2",
    "@mastra/core": "^0.23.1",
    "@mastra/libsql": "^0.16.1",
    "@mastra/loggers": "^0.10.18",
    "@mastra/memory": "^0.15.9",
    "@payloadcms/db-postgres": "3.65.0",
    "@payloadcms/next": "3.65.0",
    "@payloadcms/payload-cloud": "3.65.0",
    "@payloadcms/richtext-lexical": "3.65.0",
    "@payloadcms/sdk": "^3.65.0",
    "@payloadcms/storage-s3": "^3.65.0",
    "@payloadcms/ui": "3.65.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@ridemountainpig/svgl-react": "^1.0.13",
    "@splinetool/react-spline": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.14",
    "ai": "^5.0.80",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "framer-motion": "^12.23.24",
    "graphql": "^16.8.1",
    "gsap": "^3.13.0",
    "lucide-react": "^0.545.0",
    "mermaid": "^11.12.0",
    "motion": "^12.23.24",
    "nanoid": "^5.1.6",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "payload": "3.65.0",
    "postcss": "^8.5.6",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "react-syntax-highlighter": "^15.6.6",
    "react-zoom-pan-pinch": "^3.7.0",
    "sharp": "0.34.2",
    "sonner": "^2.0.7",
    "streamdown": "^1.6.8",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "use-stick-to-bottom": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.54.1",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.0.4",
    "jsdom": "26.1.0",
    "playwright": "1.54.1",
    "playwright-core": "1.54.1",
    "prettier": "^3.4.2",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    }
  }
}
